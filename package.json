{
  "name": "resturant-portal",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "start": "vite preview --port $PORT --host",
    "lint": "tsc --noEmit",
    "cap:sync": "npx cap sync",
    "cap:open:android": "npx cap open android",
    "android:reverse": "adb reverse tcp:5000 tcp:5000",
