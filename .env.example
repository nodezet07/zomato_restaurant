# ─── Local dev (npm run dev) — point at your PC backend ───
VITE_LAN_HOST=192.168.1.101
VITE_ANDROID_API_HOST=10.0.2.2
# VITE_API_URL=http://localhost:5000/api/v1
# VITE_SOCKET_URL=http://localhost:5000

# ─── Production Render (APK + phone testing) ───
VITE_API_URL=https://zomato-backend-pt66.onrender.com/api/v1
VITE_SOCKET_URL=https://zomato-backend-pt66.onrender.com
VITE_USE_PRODUCTION_BACKEND=true
# For LAN-only APK: VITE_USE_LOCAL_BACKEND=true and localhost URLs above

# Production APK build also loads .env.production (npm run android:apk:prod)

VITE_GOOGLE_MAPS_API_KEY=

# Optional: skip auto-detect and pin your restaurant MongoDB id
# VITE_DEFAULT_RESTAURANT_ID=
